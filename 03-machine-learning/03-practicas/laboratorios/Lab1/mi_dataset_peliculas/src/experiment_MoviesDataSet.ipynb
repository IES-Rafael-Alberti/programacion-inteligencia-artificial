    "OMDB_API_KEY = os.getenv(\"OMDB_API_KEY\")\n",
    "print(\"TMDB_API_KEY:\", TMDB_API_KEY)\n",
    "print(\"OMDB_API_KEY:\", OMDB_API_KEY)\n"
   ]
