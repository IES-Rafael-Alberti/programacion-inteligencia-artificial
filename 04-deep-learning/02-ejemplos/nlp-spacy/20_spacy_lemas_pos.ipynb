    "# Lematización y análisis morfosintáctico con spaCy\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "431ddcb5",
   "metadata": {},
   "outputs": [],
   "source": [
    "import spacy\n",
    "nlp = spacy.load('es_core_news_sm')\n",
    "text = \"Los niños estaban corriendo rápidamente por el parque.\"\n",
    "doc = nlp(text)\n",
    "for token in doc:\n",
    "    print(token.text, token.lemma_, token.pos_, token.tag_)"
   ]
  }
